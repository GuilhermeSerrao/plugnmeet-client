PLUGNMEET_SERVER_URL=https://your-plugnmeet-server.example.com
PLUGNMEET_API_KEY=your-api-key
PLUGNMEET_API_SECRET=your-api-secret

# examples/server.js and dashboard/server.js only. The shared password used to
# log in (dashboard) or authenticate admin routes (examples tester). Also
# signs the shareable join links (dashboard/server.js). Leave unset to lock
# admin/dashboard routes out entirely (safe default when deployed publicly
# without a password).
ADMIN_PASSWORD=
# examples/server.js and dashboard/server.js only.
PORT=3000
