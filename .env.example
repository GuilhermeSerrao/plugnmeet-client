PLUGNMEET_SERVER_URL=https://your-plugnmeet-server.example.com
PLUGNMEET_API_KEY=your-api-key
PLUGNMEET_API_SECRET=your-api-secret

# examples/server.js only. Protects room-management routes (create/end room,
# list active rooms) with HTTP Basic Auth. Leave unset to disable those routes
# entirely (safe default when deployed publicly without a password).
ADMIN_PASSWORD=
# examples/server.js only.
PORT=3000
